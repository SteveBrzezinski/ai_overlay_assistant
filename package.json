{
  "name": "voice-overlay-assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "format:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all --check",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "quality": "npm run lint && npm run typecheck && npm run tts:check && npm run format:check && npm run lint:rust && npm run check:rust",
    "tts": "tsx src/index.ts",
    "tts:check": "tsc -p tsconfig.tts.json --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "dotenv": "^16.4.7",
    "i18next": "^26.0.3",
    "openai": "^4.104.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.46.0",
    "vite": "^5.4.8"
  }
}
