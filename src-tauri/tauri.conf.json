{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voice Overlay Assistant",
  "version": "0.1.0",
  "identifier": "com.steve.voiceoverlayassistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Voice Overlay Assistant",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": true,
        "theme": "Dark",
        "focus": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Desktop shell for reading selected text aloud.",
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
